<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal" android:layout_marginTop="12dp"
        android:background="@drawable/bg_sheet_handle" />

    <!-- Title -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:paddingTop="16dp" android:paddingBottom="4dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/add_goal"
            android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold" />
        <ImageView android:id="@+id/btn_close" android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/ic_close" android:padding="4dp" android:contentDescription="Close" />
    </LinearLayout>

    <!-- Tab: Savings / Budget Challenge -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_goal_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabRippleColor="@null" />

    <!-- Goal Title -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_goal_title"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="16dp"
        android:hint="@string/goal_title_hint"
        app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_goal_title"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="textCapWords" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Target amount -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_target"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp"
        android:hint="@string/target_amount"
        app:prefixText="₹"
        app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_target"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Deadline (Savings only) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_deadline"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp"
        android:hint="@string/deadline_optional"
        app:endIconMode="custom" app:endIconDrawable="@drawable/ic_calendar"
        app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_deadline"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="false" android:cursorVisible="false" android:clickable="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Budget challenge: category dropdown -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_budget_category"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp"
        android:hint="@string/challenge_category"
        android:visibility="gone"
        app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp">
        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/actv_budget_category"
            android:layout_width="match_parent" android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Icon picker row -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="16dp"
        android:text="Choose Icon" android:textColor="@color/text_secondary" android:textSize="13sp" />

    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingHorizontal="20dp" android:scrollbars="none" android:layout_marginTop="8dp">
        <LinearLayout android:id="@+id/icon_picker_row"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Save button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_goal"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="20dp"
        android:text="@string/save" android:paddingVertical="14dp"
        app:cornerRadius="12dp" />

</LinearLayout>
